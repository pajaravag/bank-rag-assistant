# LLM provider (Groq free tier: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=1.0

# Conversation
HISTORY_WINDOW_N=6
CONDENSE_ENABLED=true
CONDENSE_MODEL=llama-3.1-8b-instant

# Ingestion
CHUNK_SIZE=800
CHUNK_OVERLAP=120
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Retrieval
TOP_K=8
RERANK_ENABLED=true
RERANK_TOP_K=4
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANK_SCORE_THRESHOLD=-5.0
SIMILARITY_SCORE_THRESHOLD=0.75

# Observability (Phoenix UI at http://localhost:6006; on by default in compose)
PHOENIX_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:6006/v1/traces

# Vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=bank_site

# Scraper
SCRAPE_BASE_URL=https://www.bancolombia.com/
# La cola se siembra con los sitemaps oficiales del sitio (~830 URLs en
# bancolombia.com). Con 150 el arranque es rápido (~5 min); sube a 1000
# para indexar el sitio completo (~20 min).
SCRAPE_MAX_PAGES=150
SITEMAP_SEED=true
SCRAPE_DELAY_SECONDS=0.4
SCRAPE_TIMEOUT_SECONDS=15.0

# Almacenamiento local
DATA_DIR=data
HISTORY_DB_PATH=data/history.db
